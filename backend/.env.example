# ─── Core ─────────────────────────────────────────────────────────────────────
PORT=8420
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://powderlink:devpassword@localhost:5432/powderlink

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT Auth (PL-15) ─────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-64

# ─── Stripe (PL-15) ───────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
# REQUIRED for /auth/upgrade and pro tier activation
STRIPE_SECRET_KEY=sk_test_...
# Create a recurring price in Stripe Dashboard → set the price ID here
STRIPE_PRO_PRICE_ID=price_...
# Get from: https://dashboard.stripe.com/webhooks (after registering /auth/stripe-webhook)
STRIPE_WEBHOOK_SECRET=whsec_...
# App deep-link base URL for Stripe redirect (e.g. https://powderlink.app or exp://localhost:8081)
APP_URL=https://powderlink.app

# ─── Garmin inReach (PL-10) ───────────────────────────────────────────────────
# NOTE: No server-side API key required for MapShare polling.
# Each user provides their own MapShare identifier via POST /garmin/config.
#
# MapShare identifier: found at explore.garmin.com → MapShare → Social tab
# The server polls: https://share.garmin.com/Feed/Share/{mapshare_id}
#
# OPTIONAL — Garmin Explore Enterprise API (future):
# Contact Garmin partner program for enterprise API access:
#   https://explore.garmin.com/en-US/enterprise
# GARMIN_ENTERPRISE_API_KEY=
# GARMIN_ENTERPRISE_API_URL=https://explore.garmin.com/consumer/website/api

# ─── SMS OTP (future PL-xx) ───────────────────────────────────────────────────
# Twilio credentials for phone number OTP auth
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxx
# TWILIO_FROM=+1xxxxxxxxxx

# ─── Push Notifications (future) ──────────────────────────────────────────────
# APNS_KEY_ID=
# APNS_TEAM_ID=
# APNS_PRIVATE_KEY_PATH=./certs/apns.p8
# FCM_SERVER_KEY=
